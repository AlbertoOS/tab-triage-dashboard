{
  "manifest_version": 2,
  "name": "Tab Triage",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-triage@albertoos"
    }
  },
  "description": "Full-page tab manager with sorting, filtering, grouping, and search to triage 1000+ tabs.",
  "permissions": [
    "tabs",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Tab Triage",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
