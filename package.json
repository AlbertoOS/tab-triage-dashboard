{
  "private": true,
  "name": "tab-triage-dashboard",
  "version": "1.3.2",
  "description": "Triage your tabs — sort by age, filter by status, group by domain, and close duplicates. A bit of organization to a tab chaos. :)",
  "scripts": {
    "zip": "bash build-zip.sh all",
    "zip:firefox": "bash build-zip.sh firefox",
    "zip:chrome": "bash build-zip.sh chrome",
    "lint": "bash build-zip.sh firefox && addons-linter tab-triage-dashboard-firefox.zip --boring --warnings-as-errors",
    "test": "node --test 'test/**/*.test.js'",
    "release": "bash release.sh",
    "release:publish": "bash release-publish.sh"
  },
  "devDependencies": {
    "addons-linter": "^10.3.0"
  }
}
